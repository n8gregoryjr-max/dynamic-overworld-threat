{
	"schemaVersion": 1,
	"id": "dot",
	"version": "1.0.0",
	"name": "Dynamic Overworld Threat",
	"description": "A mod that increases world danger based on player actions. Passive mobs flee and hostile mobs grow stronger as threat rises.",
	"authors": [
		"Nathaniel J. G. Jr."
	],
	"contact": {
		"sources": "https://github.com/n8gregoryjr-max/dot-mod"
	},
	"license": "MIT",
	"icon": "assets/dot/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.james.dot.DOT"
		],
		"client": [
			"com.james.dot.DOTClient"
		]
	},
	"mixins": [
		"dot.mixins.json",
		{
			"config": "dot.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	}
}
